<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_bottom_sheet">

    <!-- Drag Handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@color/border_gray" />

    <!-- Big Nominal -->
    <TextView
        android:id="@+id/tvDetailAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textColor="@color/income_green"
        android:textSize="32sp"
        android:textStyle="bold"
        tools:text="+Rp 1.500.000" />

    <!-- Type Badge -->
    <TextView
        android:id="@+id/tvDetailTypeBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_brutal_chip_filter"
        android:backgroundTint="@color/income_green_light"
        android:paddingHorizontal="16dp"
        android:paddingVertical="4dp"
        android:textColor="@color/income_green"
        android:textSize="12sp"
        android:textStyle="bold"
        tools:text="Pemasukan" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_gray"
        android:layout_marginBottom="16dp" />

    <!-- Details Rows -->
    <!-- Description -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Catatan / Deskripsi"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_main"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Penjualan katering siang untuk 50 porsi syukuran ruko baru" />
    </LinearLayout>

    <!-- Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waktu Transaksi"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_main"
            android:textSize="15sp"
            tools:text="Senin, 29 Juni 2026 19:30" />
    </LinearLayout>

    <!-- Category -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <FrameLayout
                android:id="@+id/detailCategoryIconContainer"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_icon"
                android:backgroundTint="@color/income_green_light">
                <ImageView
                    android:id="@+id/ivDetailCategoryIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_trending_up"
                    app:tint="@color/income_green"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvDetailCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Penjualan" />
        </LinearLayout>
    </LinearLayout>

    <!-- Source -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sumber Input"
            android:textColor="@color/text_muted"
            android:textSize="12sp" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            <FrameLayout
                android:id="@+id/detailSourceIconContainer"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_icon"
                android:backgroundTint="@color/primary_light">
                <ImageView
                    android:id="@+id/ivDetailSourceIcon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_edit"
                    app:tint="@color/primary"/>
            </FrameLayout>
            <TextView
                android:id="@+id/tvDetailSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_main"
                android:textSize="15sp"
                tools:text="Input Manual" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bukti Foto (Proof Photo) -->
    <LinearLayout
        android:id="@+id/layoutDetailProof"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_proof_badge"
                app:tint="@color/text_muted"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bukti Foto"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Tap-to-zoom card -->
        <FrameLayout
            android:id="@+id/cardDetailProof"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/bg_proof_preview_card"
            android:clipChildren="true"
            android:clipToPadding="false"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/ivDetailProof"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Bukti transaksi" />

            <!-- Dark gradient overlay at bottom -->
            <View
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_proof_overlay_gradient" />

            <!-- Zoom Icon & Text Overlay -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_zoom_in"
                    app:tint="@color/white"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ketuk untuk perbesar"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border_gray"
        android:layout_marginBottom="24dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnDetailDelete"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Hapus"
            android:textColor="@color/expense_red"
            android:textStyle="bold"
            android:background="@drawable/bg_brutal_button_delete"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_delete"
            app:iconTint="@color/expense_red"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnDetailEdit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1.2"
            android:text="Edit Transaksi"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:background="@drawable/bg_brutal_button_primary"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_edit"
            app:iconTint="@color/white"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</LinearLayout>
