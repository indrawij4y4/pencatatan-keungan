<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow -->
    <item android:top="3dp" android:left="3dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Foreground -->
    <item android:top="0dp" android:left="0dp" android:bottom="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_bg" />
            <stroke android:width="2dp" android:color="@color/brutal_border" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
