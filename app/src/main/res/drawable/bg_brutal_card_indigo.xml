<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow (charcoal black) -->
    <item android:top="4dp" android:left="4dp" android:bottom="0dp" android:right="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/brutal_shadow" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <!-- Foreground (violet/indigo) -->
    <item android:top="0dp" android:left="0dp" android:bottom="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/primary" />
            <stroke android:width="2dp" android:color="@color/brutal_border" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
